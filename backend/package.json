{
  "name": "project-finance-backend",
  "version": "1.0.0",
  "description": "GraphQL backend for Project Finance Management Platform",
  "type": "module",
  "main": "src/index.js",
  "scripts": {
    "dev": "node --env-file=../.env --watch src/index.js",
    "start": "node --env-file=../.env src/index.js",
    "db:generate": "node --env-file=../.env scripts/run-with-env.js prisma generate",
    "db:migrate": "node --env-file=../.env scripts/run-with-env.js prisma migrate deploy",
    "db:migrate:dev": "node --env-file=../.env scripts/run-with-env.js prisma migrate dev",
    "db:push": "node --env-file=../.env scripts/run-with-env.js prisma db push",
    "db:studio": "node --env-file=../.env scripts/run-with-env.js prisma studio",
    "test": "node --env-file=../.env --experimental-vm-modules node_modules/jest/bin/jest.js --runInBand --forceExit",
    "test:watch": "npm run test -- --watch",
    "seed:example": "node scripts/seed-example.js",
    "example:run": "node scripts/run-example.js"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@apollo/server": "^4.11.3",
    "@prisma/client": "^6.9.0",
    "bcryptjs": "^3.0.2",
    "cors": "^2.8.5",
    "dotenv": "^16.5.0",
    "express": "^4.21.2",
    "graphql": "^16.11.0",
    "jsonwebtoken": "^9.0.2",
    "nodemailer": "^8.0.10"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "prisma": "^6.9.0",
    "supertest": "^7.1.1"
  }
}
